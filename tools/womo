#!/usr/bin/env bash
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
DOCS_ROOT="$ROOT/docs/nodes"
FW_ROOT="$ROOT/firmware/esphome"
DEFAULT_ESPHOME_CONTAINER="${ESPHOME_CONTAINER:-esphome}"

show_help() {
  echo "WoMo CLI"
  echo ""
  echo "Commands:"
  echo "  womo node create <class> <name>"
  echo "  womo node list"
  echo "  womo node show <name>"
  echo "  womo node compile <name>"
  echo "  womo node config <name>"
  echo "  womo mqtt inspect [mode] [topic]"
  echo "  womo mqtt validate [topic]"
  echo "  womo docs"
  echo ""
}

normalize_node_name() {
  local input_name="$1"
  if [[ "$input_name" == womo_* ]]; then
    echo "$input_name"
  else
    echo "womo_${input_name}"
  fi
}

find_node_doc() {
  local node_name="$1"
  find "$DOCS_ROOT" -type f -name "${node_name}.md" | head -n 1
}

get_fw_file() {
  local node_name="$1"
  echo "$FW_ROOT/${node_name}.yaml"
}

ensure_fw_exists() {
  local fw_file="$1"
  if [ ! -f "$fw_file" ]; then
    echo "Firmware YAML not found: ${fw_file#$ROOT/}"
    exit 1
  fi
}

list_nodes() {
  local found=0

  for class_dir in "$DOCS_ROOT"/*; do
    [ -d "$class_dir" ] || continue
    class_name="$(basename "$class_dir")"

    while IFS= read -r file; do
      [ -n "$file" ] || continue
      node_file="$(basename "$file" .md)"
      printf "%-10s %s\n" "$class_name" "$node_file"
      found=1
    done < <(find "$class_dir" -maxdepth 1 -type f -name 'womo_*.md' | sort)
  done

  if [ "$found" -eq 0 ]; then
    echo "No nodes found."
  fi
}

show_node() {
  local input_name="$1"
  local node_name
  node_name="$(normalize_node_name "$input_name")"

  local doc_file
  local fw_file

  doc_file="$(find_node_doc "$node_name" || true)"
  fw_file="$(get_fw_file "$node_name")"

  if [ -z "$doc_file" ] && [ ! -f "$fw_file" ]; then
    echo "Node not found: $input_name"
    exit 1
  fi

  echo "Node: $node_name"
  echo ""

  if [ -n "$doc_file" ]; then
    echo "Documentation: ${doc_file#$ROOT/}"
  else
    echo "Documentation: not found"
  fi

  if [ -f "$fw_file" ]; then
    echo "Firmware:      ${fw_file#$ROOT/}"
  else
    echo "Firmware:      not found"
  fi

  echo ""

  if [ -n "$doc_file" ]; then
    echo "===== DOCUMENTATION ====="
    sed -n '1,220p' "$doc_file"
    echo ""
  fi

  if [ -f "$fw_file" ]; then
    echo "===== FIRMWARE YAML ====="
    sed -n '1,220p' "$fw_file"
    echo ""
  fi
}

compile_node() {
  local input_name="$1"
  local node_name
  local fw_file
  local config_in_container

  node_name="$(normalize_node_name "$input_name")"
  fw_file="$(get_fw_file "$node_name")"
  ensure_fw_exists "$fw_file"

  config_in_container="/config/${node_name}.yaml"

  echo "Compiling node: $node_name"
  echo "Container: $DEFAULT_ESPHOME_CONTAINER"
  echo "Config:    $config_in_container"
  echo ""

  docker exec -it "$DEFAULT_ESPHOME_CONTAINER" esphome compile "$config_in_container"
}

show_config_node() {
  local input_name="$1"
  local node_name
  local fw_file
  local config_in_container

  node_name="$(normalize_node_name "$input_name")"
  fw_file="$(get_fw_file "$node_name")"
  ensure_fw_exists "$fw_file"

  config_in_container="/config/${node_name}.yaml"

  echo "Rendering config for: $node_name"
  echo "Container: $DEFAULT_ESPHOME_CONTAINER"
  echo "Config:    $config_in_container"
  echo ""

  docker exec -it "$DEFAULT_ESPHOME_CONTAINER" esphome config "$config_in_container"
}

CMD="${1:-}"

case "$CMD" in

node)
  shift || true
  SUB="${1:-}"
  shift || true

  case "$SUB" in
    create)
      "$ROOT/firmware/tools/create-node.sh" "$@"
      ;;
    list)
      list_nodes
      ;;
    show)
      if [ $# -lt 1 ]; then
        echo "Usage: womo node show <name>"
        exit 1
      fi
      show_node "$1"
      ;;
    compile)
      if [ $# -lt 1 ]; then
        echo "Usage: womo node compile <name>"
        exit 1
      fi
      compile_node "$1"
      ;;
    config)
      if [ $# -lt 1 ]; then
        echo "Usage: womo node config <name>"
        exit 1
      fi
      show_config_node "$1"
      ;;
    *)
      show_help
      ;;
  esac
  ;;

mqtt)
  shift || true
  SUB="${1:-}"
  shift || true

  case "$SUB" in
    inspect)
      "$ROOT/infrastructure/mqtt/mqtt-inspect.sh" "$@"
      ;;
    validate)
      "$ROOT/infrastructure/mqtt/mqtt-validate-topics.sh" "$@"
      ;;
    *)
      show_help
      ;;
  esac
  ;;

docs)
  ls "$ROOT/docs"
  ;;

*)
  show_help
  ;;

esac
